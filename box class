#include<iostream>
using namespace std;

class Box{
    int volume;
public:
    Box(int v){
        volume=v;
    }

    bool operator >(Box b){
        return volume>b.volume;
    }
};

int main(){
    Box b1(50), b2(70);

    if(b1>b2)
        cout<<"Box1 is greater";
    else
        cout<<"Box2 is greater";
}
