#include<iostream>
#include<cstring>
using namespace std;

class Student{
    char *name;
    int marks;
public:
    Student(char n[], int m){
        name = new char[strlen(n)+1];
        strcpy(name,n);
        marks = m;
    }

    Student(const Student &s){
        name = new char[strlen(s.name)+1];
        strcpy(name,s.name);
        marks = s.marks;
    }

    void setName(char n[]){
        strcpy(name,n);
    }

    void display(){
        cout<<"Name: "<<name<<"\nMarks: "<<marks<<endl;
    }
};

int main(){
    Student s1("Ram",90);
    Student s2=s1;

    s2.setName("Sam");

    s1.display();
    s2.display();
}
