#include<iostream>
using namespace std;

class Employee{
    char *name;
    int salary;
public:
    Employee(char n[], int s){
        name = new char[20];
        strcpy(name,n);
        salary = s;
        cout<<"Constructor called\n";
    }

    ~Employee(){
        delete[] name;
        cout<<"Destructor called\n";
    }

    void display(){
        cout<<name<<" "<<salary;
    }
};

int main(){
    Employee e("John",50000);
    e.display();
}
